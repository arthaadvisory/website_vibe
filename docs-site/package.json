{
  "name": "vitepress-docs-template",
  "version": "1.0.0",
  "type": "module",
  "description": "A VitePress site",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:clean": "node -e \"require('fs').rmSync('docs/.vitepress/dist',{recursive:true,force:true})\"",
    "docs:build": "npm run docs:clean && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "feed": "^5.2.0",
    "mermaid": "^11.12.2",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitepress": "^1.0.0-rc.31",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.3.4"
  },
  "dependencies": {
    "markdown-it-mathjax3": "^4.3.2",
    "medium-zoom": "^1.1.0"
  }
}
